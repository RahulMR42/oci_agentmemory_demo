# Minimum required input if you are not using TF_VAR_compartment_ocid.
compartment_ocid = "ocid1.compartment.oc1..replaceMe"

# Optional overrides. Everything below already has a Terraform default.
# Terraform appends a stable random 6-character suffix to generated OCI resource names.
# Set the base names below and let Terraform add the suffix automatically.
# region = "us-chicago-1"
# policy_compartment_ocid = "ocid1.compartment.oc1..replaceMe"
# oci_cli_profile = "DEFAULT"
